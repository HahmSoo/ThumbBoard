<!-- Views/TagManageDialog.xaml -->
<Window x:Class="ArchiveThumbViewer.Views.TagManageDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Tag 설정"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Width="328" Height="560"
        Background="#3a3a3a"
        FontSize="14">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="전체 태그 목록" Foreground="#DDD" Margin="0,0,0,8"/>

        <Border Grid.Row="1" Background="#4e4e4e" Padding="6">
            <DockPanel>
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
                    <TextBox x:Name="NewTagBox" Width="166" Height="28" Margin="0,0,8,0"
                             ToolTip="새 태그를 입력하세요"/>
                    <Button Content="추가" Padding="12,4" Click="OnAdd"/>
                    <Button Content="정렬" Padding="12,4" Margin="8,0,0,0" Click="OnSort"/>
                </StackPanel>

                <ListBox x:Name="TagList"
                         Background="#4e4e4e"
         SelectionMode="Extended"
         AllowDrop="True"
         PreviewMouseLeftButtonDown="OnListMouseDown"
         PreviewMouseMove="OnListMouseMove"
         Drop="OnListDrop"
         DragOver="OnListDragOver">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="28"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0"
                        Width="18" Height="18"
                        CornerRadius="3"
                        Background="{Binding ColorBrush}"
                        
                        HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Border.InputBindings>
                                        <MouseBinding Gesture="LeftClick"
                                      Command="{Binding DataContext.CmdPickColor, RelativeSource={RelativeSource AncestorType=Window}}"
                                      CommandParameter="{Binding}"/>
                                    </Border.InputBindings>
                                    <Border.ToolTip>
                                        <TextBlock Text="{Binding ColorHex}" />
                                    </Border.ToolTip>
                                </Border>
                                <TextBlock Grid.Column="1"
                           Text="{Binding Name}"
                           Foreground="#EEE"
                           VerticalAlignment="Center"
                           Margin="8,0,0,0"/>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

            </DockPanel>
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
            <Button Content="선택 삭제" Width="100" Margin="0,0,8,0" Click="OnDelete"/>
            <Button Content="확인" Width="88" Margin="0,0,8,0" IsDefault="True" Click="OnOk"/>
            <Button Content="취소" Width="88" IsCancel="True" Click="OnCancel"/>
        </StackPanel>
    </Grid>
</Window>
