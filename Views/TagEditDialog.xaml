<Window x:Class="ArchiveThumbViewer.Views.TagEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="태그 편집" Height="390" Width="208"
        ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="CenterOwner"
        Background="#2B2B2B"
        UseLayoutRounding="True" SnapsToDevicePixels="True"
        PreviewMouseRightButtonUp="Window_PreviewMouseRightButtonUp">

    <Window.Resources>
        <!-- 체크 항목 텍스트 스타일 -->
        <Style TargetType="TextBlock" x:Key="ItemText">
            <Setter Property="Foreground" Value="#EFEFEF"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <!-- 체크박스 스타일(여백 통일) -->
        <Style TargetType="CheckBox" x:Key="ListCheckBox">
            <Setter Property="Margin" Value="4,2"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- 헤더 -->
            <RowDefinition/>
            <!-- 목록 -->
            <RowDefinition Height="Auto"/>
            <!-- 버튼 -->
        </Grid.RowDefinitions>

        <!-- 헤더 -->
        <Border Grid.Row="0" Background="#3A3A3A" Padding="12,8">
            <TextBlock Text="적용할 태그를 선택하세요" Foreground="#FFFFFF" FontWeight="SemiBold"/>
        </Border>

        <!-- 목록 -->
        <Border Grid.Row="1" Padding="8,10" Background="#2B2B2B">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding TagOptions}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <CheckBox Style="{StaticResource ListCheckBox}"
                                      IsChecked="{Binding IsChecked, Mode=TwoWay}">
                                <TextBlock Style="{StaticResource ItemText}" Text="{Binding Name}"/>
                            </CheckBox>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <!-- 버튼 -->
        <DockPanel Grid.Row="2" LastChildFill="False" Background="#2B2B2B" Margin="8,0,8,8">
            <Button Content="Clear" Padding="12,6" Margin="0,8,8,0"
                    Click="ClearAll_Click" DockPanel.Dock="Left"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" DockPanel.Dock="Right">
                <Button Content="확인" Padding="12,6" Margin="0,8,8,0"
                        IsCancel="True" Click="Ok_Click"/>
                <Button Content="취소" Padding="16,6" Margin="0,8,0,0"
                        IsDefault="True" Click="Cancel_Click"/>
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>
