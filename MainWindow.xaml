<Window x:Class="ArchiveThumbViewer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:models="clr-namespace:ArchiveThumbViewer.Models"
        xmlns:controls="clr-namespace:ArchiveThumbViewer.Controls"
        xmlns:utils="clr-namespace:ArchiveThumbViewer.Utils"
        mc:Ignorable="d"
        Title="ArchiveThumbViewer" Height="720" Width="1180"
        PreviewMouseWheel="Window_PreviewMouseWheel"
        PreviewMouseDown="Window_PreviewMouseDown"
        UseLayoutRounding="True" SnapsToDevicePixels="True">

    <!-- Backspace = 상위 폴더 이동 -->
    <Window.InputBindings>
        <KeyBinding Key="Back" Command="{Binding CmdGoUp}"/>
    </Window.InputBindings>

    <!-- Resources -->
    <Window.Resources>
        <utils:MultiplyConverter x:Key="Mul"/>
        <utils:TagToBrushConverter x:Key="TagToBrush"/>

        <!-- 선택 효과 그림자 -->
        <DropShadowEffect x:Key="SelShadow"
                          Color="#66D1FF" BlurRadius="18"
                          Direction="270" ShadowDepth="0" Opacity="0.8"/>

        <!-- 배지 텍스트 스타일 -->
        <Style x:Key="BadgeText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="LineStackingStrategy" Value="BlockLineHeight"/>
            <Setter Property="LineHeight" Value="13"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextOptions.TextFormattingMode" Value="Display"/>
            <Setter Property="TextOptions.TextRenderingMode" Value="ClearType"/>
            <Setter Property="TextTrimming" Value="None"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <!-- 태그 칩 텍스트 스타일 -->
        <Style x:Key="TagChipText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="LineStackingStrategy" Value="BlockLineHeight"/>
            <Setter Property="LineHeight" Value="13"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextOptions.TextFormattingMode" Value="Display"/>
            <Setter Property="TextOptions.TextRenderingMode" Value="ClearType"/>
            <Setter Property="TextTrimming" Value="None"/>
            <Setter Property="FontWeight" Value="Normal"/>
        </Style>

        <!-- 좌측 태그 토글: 선택 시 테두리만 표시하되 크기 변화 없음 -->
        <Style x:Key="TagToggleStyle" TargetType="ToggleButton">
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Foreground" Value="White"/>
            <!-- 두께는 항상 2px로 고정 -->
            <Setter Property="BorderThickness" Value="2"/>
            <!-- 기본은 투명 테두리 = 보이진 않지만 자리 차지해서 크기불변 -->
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3"
                                SnapsToDevicePixels="True"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <!-- 체크되면 흰색 테두리만 보이게 (두께는 그대로 2px) -->
                                <Setter TargetName="Root" Property="BorderBrush" Value="#FFFFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- DataContext는 MainWindow.xaml.cs에서 주입 -->

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition/>
            <RowDefinition Height="28"/>
        </Grid.RowDefinitions>

        <!-- 상단 메뉴 -->
        <Border Grid.Row="0" Background="#3a3a3a" Padding="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- 좌측: 경로/뷰어설정/캐시 -->
                <StackPanel Orientation="Horizontal" Grid.Column="0" HorizontalAlignment="Left">
                    <Button Content="경로설정" Padding="14,6" Margin="0,0,8,0" Command="{Binding CmdBrowsePath}"/>
                    <Button Content="뷰어설정" Padding="14,6" Margin="0,0,8,0" Command="{Binding CmdOpenViewerSettings}"/>
                    <Button Content="폴더 열기" Padding="14,6" Margin="0,0,8,0" Command="{Binding CmdOpenRootFolder}"/>
                    <Button Content="캐시 초기화" Padding="14,6" Command="{Binding CmdClearCache}" />
                </StackPanel>

                <!-- 우측: 정렬/검색 -->
                <StackPanel Orientation="Horizontal" Grid.Column="1" HorizontalAlignment="Right">
                    <Button Content="제목순"   Padding="12,6" Margin="0,0,8,0" Command="{Binding CmdSortTitle}"/>
                    <Button Content="작가순"   Padding="12,6" Margin="0,0,8,0" Command="{Binding CmdSortAuthor}"/>
                    <Button Content="파일명순" Padding="12,6" Margin="0,0,8,0" Command="{Binding CmdSortFileName}"/>

                    <TextBox Width="220" Height="28" VerticalAlignment="Center"
                             Margin="8,0,8,0"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"/>
                    <Button Content="검색 초기화" Padding="10,6" Command="{Binding CmdClearSearch}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 본문 -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="130"/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>

            <!-- 좌측 태그 패널 -->
            <DockPanel Grid.Column="0" Background="#3a3a3a">
                <StackPanel DockPanel.Dock="Top" Margin="10">
                    <Button Content="Tag설정"  Padding="10,6" Margin="0,4,0,7" Command="{Binding CmdOpenTagSettings}"/>
                    <Button Content="Tag 초기화" Command="{Binding CmdClearTags}" Padding="10,6"/>
                </StackPanel>

                <ScrollViewer DockPanel.Dock="Bottom" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding AllTags}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <ToggleButton IsChecked="{Binding IsSelected}"
                                              Margin="10,4,10,4"
                                              Padding="10,6"
                                              Background="{Binding ColorBrush}"
                                              Foreground="White"
                                              Style="{StaticResource TagToggleStyle}"
                                              PreviewMouseDown="Tag_Toggle_PreviewMouseDown"
                                              PreviewMouseMove="Tag_Toggle_PreviewMouseMove">
                                    <TextBlock Text="{Binding Name}"/>
                                    <ToggleButton.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="색상 지정..." Click="OnPickTagColor"/>
                                        </ContextMenu>
                                    </ToggleButton.ContextMenu>
                                </ToggleButton>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </DockPanel>

            <!-- 메인 썸네일 그리드 -->
            <ListBox x:Name="ThumbList"
                     Grid.Column="1"
                     ItemsSource="{Binding ItemsView}"
                     Background="#4e4e4e" BorderThickness="0"
                     SelectionMode="Single"
                     PreviewKeyDown="ThumbList_PreviewKeyDown"
                     ScrollViewer.CanContentScroll="True"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     ScrollViewer.IsDeferredScrollingEnabled="True"
                     VirtualizingPanel.IsVirtualizing="True"
                     VirtualizingPanel.VirtualizationMode="Recycling"
                     VirtualizingPanel.ScrollUnit="Pixel">

                <ListBox.InputBindings>
                    <!-- 메인키보드 Enter -->
                    <KeyBinding Key="Return"
                                Command="{Binding CmdItemDoubleClick}"
                                CommandParameter="{Binding SelectedItem, ElementName=ThumbList}"/>
                    <!-- 넘패드 Enter -->
                    <KeyBinding Key="Enter"
                                Command="{Binding CmdItemDoubleClick}"
                                CommandParameter="{Binding SelectedItem, ElementName=ThumbList}"/>
                </ListBox.InputBindings>

                <!-- 썸네일 카드 템플릿 -->
                <ListBox.Resources>
                    <DataTemplate DataType="{x:Type models:ThumbnailItem}">
                        <Border x:Name="Card"
                                Background="#1f1f1f"
                                CornerRadius="10"
                                HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                                utils:CornerClip.Radius="10"
                                Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Window}}"
                                AllowDrop="True"
                                DragEnter="ListBoxItem_DragEnter"
                                DragOver="ListBoxItem_DragOver"
                                DragLeave="ListBoxItem_DragLeave"
                                Drop="ListBoxItem_Drop"
                                BorderThickness="0"
                                BorderBrush="#2A2F36">

                            <Grid>
                                <!-- 이미지 레이어 (라운딩 유지) -->
                                <Border CornerRadius="10" utils:CornerClip.Radius="10">
                                    <Grid>
                                        <Image Source="{Binding Thumbnail}"
                                               Stretch="Uniform"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               RenderOptions.BitmapScalingMode="HighQuality"/>
                                        <Grid x:Name="Placeholder" Background="#1f1f1f" Visibility="Collapsed">
                                            <TextBlock Text="" Foreground="#777"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Grid>
                                    </Grid>
                                </Border>

                                <!-- (폴더 전용) 중앙 폴더명 -->
                                <Border x:Name="FolderCenter"
                                        Background="#66000000"
                                        Padding="10,6"
                                        CornerRadius="6"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Visibility="Collapsed"
                                        Panel.ZIndex="12">
                                    <TextBlock Text="{Binding RawName}"
                                               Foreground="#FFFFFF"
                                               FontWeight="Bold"
                                               TextAlignment="Center"
                                               TextWrapping="Wrap"
                                               MaxWidth="220"/>
                                </Border>

                                <!-- (ZIP 전용) 하단 오버레이 -->
                                <Border x:Name="Overlay"
                                        Background="#BB000000"
                                        CornerRadius="0,0,10,10"
                                        MinHeight="50"
                                        VerticalAlignment="Bottom"
                                        Padding="10,8,10,6"
                                        TextOptions.TextFormattingMode="Display"
                                        TextOptions.TextRenderingMode="ClearType">
                                    <!-- 오버레이 내부: 콘텐츠 Grid(1~3행) + 겹침 Canvas(0행 역할) -->
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <!-- 0행 역할: 배지(오버레이 상단 넘어서 보임) -->
                                        <Canvas Grid.Row="0"
                                                IsHitTestVisible="False"
                                                HorizontalAlignment="Left"
                                                VerticalAlignment="Top">
                                            <Border Background="#BB000000" CornerRadius="0,3,0,0"
                                                    Padding="10,4,10,0"
                                                    Margin="-10,-25,0,10"
                                                    Panel.ZIndex="10">
                                                <TextBlock Style="{StaticResource BadgeText}"
                                                           Foreground="#FFFFFF"
                                                           Text="{Binding EntryCount}"/>
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding EntryCount}" Value="{x:Null}">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                            </Border>
                                        </Canvas>

                                        <!-- 1) 작가 -->
                                        <TextBlock Grid.Row="1"
                                                   Text="{Binding Author}"
                                                   FontWeight="Black"
                                                   Foreground="#ffffff"
                                                   Opacity="1"
                                                   TextTrimming="CharacterEllipsis"
                                                   Margin="0,-2,0,2"/>

                                        <!-- 2) 제목 -->
                                        <TextBlock Grid.Row="2"
                                                   Text="{Binding Title}"
                                                   FontWeight="Bold"
                                                   Foreground="#82FF90"
                                                   TextWrapping="Wrap"
                                                   Margin="0,0,0,5"/>

                                        <!-- 3) 태그 -->
                                        <ItemsControl Grid.Row="3" ItemsSource="{Binding Tags}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border CornerRadius="2"
                                                            Padding="4,2" Margin="0,0,3,4"
                                                            VerticalAlignment="Center">
                                                        <Border.Background>
                                                            <MultiBinding Converter="{StaticResource TagToBrush}">
                                                                <!-- 태그 이름 -->
                                                                <Binding/>
                                                                <!-- VM의 AllTags -->
                                                                <Binding RelativeSource="{RelativeSource AncestorType=Window}"
                                                                         Path="DataContext.AllTags"/>
                                                            </MultiBinding>
                                                        </Border.Background>
                                                        <TextBlock Style="{StaticResource TagChipText}"
                                                                   Foreground="#FFFFFF"
                                                                   Text="{Binding}"/>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Border>

                        <!-- 트리거들 -->
                        <DataTemplate.Triggers>
                            <!-- 썸네일 없을 때 플레이스홀더 -->
                            <DataTrigger Binding="{Binding Thumbnail}" Value="{x:Null}">
                                <Setter TargetName="Placeholder" Property="Visibility" Value="Visible"/>
                            </DataTrigger>

                            <!-- 폴더: 중앙 폴더명 보이기 + 오버레이 숨기기 -->
                            <DataTrigger Binding="{Binding IsFolder}" Value="True">
                                <Setter TargetName="FolderCenter" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="Overlay" Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>

                            <!-- 파일(ZIP 등): 오버레이 보이기 -->
                            <DataTrigger Binding="{Binding IsFolder}" Value="False">
                                <Setter TargetName="FolderCenter" Property="Visibility" Value="Collapsed"/>
                                <Setter TargetName="Overlay" Property="Visibility" Value="Visible"/>
                            </DataTrigger>

                            <!-- 선택 효과 -->
                            <DataTrigger Value="True"
                                         Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}">
                                <Setter TargetName="Card" Property="BorderBrush" Value="#66D1FF"/>
                                <Setter TargetName="Card" Property="BorderThickness" Value="2.5"/>
                                <Setter TargetName="Card" Property="Background" Value="#66D1FF"/>
                                <Setter TargetName="Card" Property="Effect" Value="{StaticResource SelShadow}"/>
                                <Setter TargetName="Card" Property="RenderTransformOrigin" Value="0.5,0.5"/>
                                <Setter TargetName="Card" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="1.00" ScaleY="1.00"/>
                                    </Setter.Value>
                                </Setter>
                            </DataTrigger>

                            <!-- 호버(선택 아님) -->
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True"/>
                                    <Condition Binding="{Binding IsSelected,   RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="False"/>
                                </MultiDataTrigger.Conditions>
                                <Setter TargetName="Card" Property="BorderBrush" Value="#3A90FF"/>
                                <Setter TargetName="Card" Property="BorderThickness" Value="2.5"/>
                                <Setter TargetName="Card" Property="Background" Value="#3A90FF"/>
                            </MultiDataTrigger>
                        </DataTemplate.Triggers>
                    </DataTemplate>
                </ListBox.Resources>

                <!-- ItemsPanel -->
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <controls:VirtualizingWrapPanel
                            ItemWidth="{Binding DataContext.Scale, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource Mul}, ConverterParameter=255}"
                            ItemHeight="{Binding DataContext.Scale, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource Mul}, ConverterParameter=360}"
                            ItemGap="8"/>
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>

                <!-- 컨테이너 -->
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Margin" Value="0"/>
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="Background" Value="{x:Null}"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Focusable" Value="True"/>
                        <Setter Property="Width"
                                Value="{Binding ItemWidth, RelativeSource={RelativeSource AncestorType={x:Type controls:VirtualizingWrapPanel}}}"/>
                        <Setter Property="Height"
                                Value="{Binding ItemHeight, RelativeSource={RelativeSource AncestorType={x:Type controls:VirtualizingWrapPanel}}}"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <ContentPresenter/>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <!-- 기존 더블클릭 유지 -->
                        <EventSetter Event="MouseDoubleClick" Handler="ListBoxItem_MouseDoubleClick"/>
                        <!-- 우클릭하면 TagEditDialog 바로 열기 -->
                        <EventSetter Event="MouseRightButtonUp" Handler="ThumbList_MouseRightButtonUp"/>
                    </Style>
                </ListBox.ItemContainerStyle>
            </ListBox>
        </Grid>

        <!-- 상태바 (우측 정렬) -->
        <Border Grid.Row="2" Background="#1f1f1f" BorderThickness="1,0,0,0" BorderBrush="#222" Padding="0,0,12,0">
            <TextBlock Text="{Binding StatusCenter}"
                       HorizontalAlignment="Right"
                       VerticalAlignment="Center"
                       TextAlignment="Right"
                       Foreground="#CFCFCF"/>
        </Border>
    </Grid>
</Window>
